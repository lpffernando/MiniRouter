# Routing tuning — baked into the image as /app/.env (KEY-FREE).
# Secrets (provider API keys) are NEVER baked; they come from runtime -e vars.
# Edit boundary values here so a rebuild keeps the tuning effective.
MINIROUTER_CONFIDENCE_THRESHOLD=0.55
MINIROUTER_CONFIDENCE_STEEPNESS=12
MINIROUTER_BOUNDARY_SIMPLE_MEDIUM=0.10
MINIROUTER_BOUNDARY_MEDIUM_COMPLEX=0.3
MINIROUTER_BOUNDARY_COMPLEX_REASONING=0.5
MINIROUTER_TOKEN_COUNT_SIMPLE=50
MINIROUTER_TOKEN_COUNT_COMPLEX=500
MINIROUTER_AMBIGUOUS_DEFAULT_TIER=MEDIUM
MINIROUTER_STRUCTURED_OUTPUT_MIN_TIER=MEDIUM
MINIROUTER_AGENTIC_SCORE_THRESHOLD=0.5
