# MiniRouter runtime environment — EXAMPLE (copy to `.env`, fill in secrets).
# `.env` is gitignored; never commit real keys.
#
# Two roles:
#   1. SSH creds  -> used by `deploy/deploy.mjs` to upload + recreate.
#   2. Provider keys -> the SERVER's `.env` (at /opt/minirouter-src/.env)
#      is the source of truth for API keys at runtime (loaded via
#      `docker compose` `env_file:`). This example lists them so you know
#      what the server .env must contain; do NOT put real keys here.

# ── SSH / deploy (local only, read by deploy/deploy.mjs) ──
MINIROUTER_SSH_HOST=101.34.34.27
MINIROUTER_SSH_PORT=222
MINIROUTER_SSH_USER=root
MINIROUTER_SSH_PASSWORD=CHANGE_ME

# ── Provider: opencode.go (all three tiers share one key) ──
# These values live in the SERVER's .env. Listed here for reference.
MINIROUTER_FAST_BASE_URL=https://opencode.ai/zen/go/v1
MINIROUTER_FAST_API_KEY=PASTE_SECRET_KEY_HERE
MINIROUTER_FAST_MODEL=deepseek-v4-flash
MINIROUTER_BALANCED_BASE_URL=https://opencode.ai/zen/go/v1
MINIROUTER_BALANCED_API_KEY=PASTE_SECRET_KEY_HERE
MINIROUTER_BALANCED_MODEL=deepseek-v4-pro
MINIROUTER_STRONG_BASE_URL=https://opencode.ai/zen/go/v1
MINIROUTER_STRONG_API_KEY=PASTE_SECRET_KEY_HERE
MINIROUTER_STRONG_MODEL=glm-5.2

# ── Runtime policy (pinned in docker-compose.yml; override server .env) ──
# MINIROUTER_SOLO=false
# MINIROUTER_PORT=8402
# BLOCKRUN_PROXY_PORT=8402
# MINIROUTER_CONFIDENCE_THRESHOLD=0.55
# MINIROUTER_CONFIDENCE_STEEPNESS=12
# MINIROUTER_BOUNDARY_SIMPLE_MEDIUM=0.10
# MINIROUTER_BOUNDARY_MEDIUM_COMPLEX=0.3
# MINIROUTER_BOUNDARY_COMPLEX_REASONING=0.5
# MINIROUTER_TOKEN_COUNT_SIMPLE=50
# MINIROUTER_TOKEN_COUNT_COMPLEX=500
# MINIROUTER_AMBIGUOUS_DEFAULT_TIER=SIMPLE
# MINIROUTER_STRUCTURED_OUTPUT_MIN_TIER=SIMPLE
# MINIROUTER_AGENTIC_SCORE_THRESHOLD=0.5
