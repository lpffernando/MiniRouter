# MiniRouter runtime configuration
# Copy to .env and replace every `replace-me` value before starting.
#
# Only BALANCED, STRONG, and VISION slots are required for the service
# to pass its readiness check. All other variables are optional and
# default to the values shown in the comments.

# ─── Server ───────────────────────────────────────────────────────────

# Local development only. In production set this to false and configure
# MINIROUTER_BOOTSTRAP_ADMIN_EMAIL for a one-time initial administrator.
MINIROUTER_SOLO=true

# Port the HTTP API listens on. Default: 8402
MINIROUTER_PORT=8402

# Set to "true" once to print extra diagnostics to stdout.
# Default: false
# MINIROUTER_DEBUG_LOG=false

# ─── Cost accounting ──────────────────────────────────────────────────

# Exchange rate used when upstream model prices are in CNY.
# Default: 7.2
MINIROUTER_CNY_PER_USD=7.2

# ─── Bootstrap ────────────────────────────────────────────────────────

# Set this only for the first production start with MINIROUTER_SOLO=false.
# The generated API key is written once to the service log; remove this
# value after saving the key.
# MINIROUTER_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# ─── Model slots (REQUIRED for readiness) ─────────────────────────────
#
# The provider can be omitted for auto-detection or set explicitly to
# `openai-compatible` or `anthropic`.
#
# At minimum you must configure BALANCED, STRONG, and VISION.
# FAST is optional — when omitted, simple requests fall back to BALANCED.
#
# Each slot needs:
#   BASE_URL         – upstream API endpoint
#   API_KEY          – provider authentication key
#   MODEL            – model identifier the upstream expects
#   SUPPORTS_TOOLS   – whether the model supports function/tool calling
#   SUPPORTS_VISION  – whether the model supports image inputs
#   CONTEXT_WINDOW   – maximum context length in tokens

MINIROUTER_BALANCED_PROVIDER=openai-compatible
MINIROUTER_BALANCED_BASE_URL=https://api.example.com/v1
MINIROUTER_BALANCED_API_KEY=replace-me
MINIROUTER_BALANCED_MODEL=replace-me
MINIROUTER_BALANCED_SUPPORTS_TOOLS=true
MINIROUTER_BALANCED_SUPPORTS_VISION=false
MINIROUTER_BALANCED_CONTEXT_WINDOW=128000

MINIROUTER_STRONG_PROVIDER=openai-compatible
MINIROUTER_STRONG_BASE_URL=https://api.example.com/v1
MINIROUTER_STRONG_API_KEY=replace-me
MINIROUTER_STRONG_MODEL=replace-me
MINIROUTER_STRONG_SUPPORTS_TOOLS=true
MINIROUTER_STRONG_SUPPORTS_VISION=false
MINIROUTER_STRONG_CONTEXT_WINDOW=128000

# Vision requests always route to this slot. Set SUPPORTS_VISION=true
# and point it to an image-capable model.
MINIROUTER_VISION_PROVIDER=openai-compatible
MINIROUTER_VISION_BASE_URL=https://api.example.com/v1
MINIROUTER_VISION_API_KEY=replace-me
MINIROUTER_VISION_MODEL=replace-me
MINIROUTER_VISION_SUPPORTS_TOOLS=false
MINIROUTER_VISION_SUPPORTS_VISION=true
MINIROUTER_VISION_CONTEXT_WINDOW=32768

# Optional fast slot for explicit minirouter/slot/fast requests.
# When omitted or commented out, simple requests fall back to BALANCED.
# MINIROUTER_FAST_PROVIDER=openai-compatible
# MINIROUTER_FAST_BASE_URL=https://api.example.com/v1
# MINIROUTER_FAST_API_KEY=replace-me
# MINIROUTER_FAST_MODEL=replace-me
# MINIROUTER_FAST_SUPPORTS_TOOLS=true
# MINIROUTER_FAST_SUPPORTS_VISION=false
# MINIROUTER_FAST_CONTEXT_WINDOW=128000

# ─── Routing tuning (optional — defaults shown in comments) ──────────
#
# The 14-dimension rule classifier maps an aggregate score to a tier:
#   SIMPLE < 0.10  ≤  MEDIUM < 0.3  ≤  COMPLEX < 0.5  ≤  REASONING
#
# These boundaries and thresholds can be tuned without rebuilding.

# Score thresholds that separate the four difficulty tiers.
# MINIROUTER_BOUNDARY_SIMPLE_MEDIUM=0.10
# MINIROUTER_BOUNDARY_MEDIUM_COMPLEX=0.3
# MINIROUTER_BOUNDARY_COMPLEX_REASONING=0.5

# Token-count thresholds for the tokenCount scoring dimension.
# Requests with ≤simple tokens are nudged down; ≥complex are nudged up.
# MINIROUTER_TOKEN_COUNT_SIMPLE=50
# MINIROUTER_TOKEN_COUNT_COMPLEX=500

# Sigmoid steepness for confidence calibration. Higher = sharper.
# MINIROUTER_CONFIDENCE_STEEPNESS=12

# Below this confidence the router falls back to the ambiguous tier.
# MINIROUTER_CONFIDENCE_THRESHOLD=0.55

# Tier used when confidence is below the threshold. One of:
# SIMPLE, MEDIUM, COMPLEX, REASONING.
# MINIROUTER_AMBIGUOUS_DEFAULT_TIER=MEDIUM

# Requests with a structured output (JSON mode, tool_choice, etc.)
# are forced to at least this tier.
# MINIROUTER_STRUCTURED_OUTPUT_MIN_TIER=SIMPLE

# When the agentic-task dimension score exceeds this value the router
# switches into agentic tier mapping (favouring tool-capable slots).
# MINIROUTER_AGENTIC_SCORE_THRESHOLD=0.5

# Force agentic routing mode. Default: auto-detect (enabled when tools present).
# Set to "true" to always use agentic tiers; "false" to disable entirely.
# MINIROUTER_AGENTIC_MODE=

# JSON object overriding the 14 dimension weights.
# Example: {"keywordCount":0.15,"instructionComplexity":0.12,"agenticTask":0.08}
# MINIROUTER_DIMENSION_WEIGHTS=

# ─── Context optimization (optional — off by default) ─────────────────
#
# MiniRouter supports Headroom for context window management and local
# tail compression. Both are disabled by default.

# Enable the external Headroom service.
# MINIROUTER_HEADROOM_ENABLED=false
# One of: off | adaptive | force
# MINIROUTER_HEADROOM_MODE=adaptive
# Headroom API endpoint.
# MINIROUTER_HEADROOM_URL=http://localhost:8787
# Minimum estimated token count before Headroom is invoked.
# MINIROUTER_HEADROOM_MIN_TOKENS=8000
# Fraction of the selected slot's context window that triggers Headroom.
# MINIROUTER_HEADROOM_CONTEXT_RATIO=0.85

# Local tail compression (no external service needed). Trims the tail
# of long contexts before forwarding to the upstream provider.
# MINIROUTER_TAIL_COMPRESSION_ENABLED=false
# MINIROUTER_TAIL_COMPRESSION_MIN_CHARS=12000
# MINIROUTER_TAIL_COMPRESSION_MAX_CHARS=2000
