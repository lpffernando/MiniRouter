{
  "name": "minirouter",
  "version": "0.1.0",
  "private": true,
  "description": "An OpenAI- and Anthropic-compatible LLM routing gateway.",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "serve": "tsx src/server/serve.ts",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "seed:models": "tsx models/seed-models.ts",
    "format": "prettier --write .",
    "start": "node dist/serve.js"
  },
  "keywords": [
    "llm",
    "router",
    "smart-routing",
    "ai",
    "cost-optimization",
    "openai",
    "anthropic",
    "gemini",
    "deepseek",
    "llm-gateway"
  ],
  "author": "MiniRouter contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lpffernando/MiniRouter.git"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "headroom-ai": "^0.22.4",
    "hono": "^4.12.27",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "basic-ftp": "^5.3.1",
    "ws": "^8.21.0",
    "postcss": "^8.5.10",
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=22"
  }
}
